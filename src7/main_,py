def call_format_agent(
    doc_type: str,
    context: str,
    existing_code: str | None = None,
    format_feedback: str | None = None,
) -> str:
    if existing_code and format_feedback:
        user_msg = (
            f"Document type: {doc_type}\nContext: {context}\n\n"
            f"Existing render_document() code:\n{existing_code}\n\n"
            f"Formatting changes requested: {format_feedback}\n\n"
            "Rewrite the complete render_document() incorporating these changes. "
            "Keep everything not mentioned in the feedback unchanged."
        )
    else:
        user_msg = (
            f"Document type: {doc_type}\nContext: {context}\n\n"
            "Write the render_document() function for this document."
        )

    # ── Route by doc_type ────────────────────────────────────────────────────
    if doc_type == "pptx":
        # Groq — LLaMA 3.3 70B (free tier, superior code quality for presentations)
        print(f"  [Format Agent] Generating PPTX formatting code via Groq LLaMA-3.3-70b...")
        resp = requests.post(
            "https://api.groq.com/openai/v1/chat/completions",
            headers={
                "Authorization": f"Bearer {GROQ_API_KEY}",
                "Content-Type": "application/json",
            },
            json={
                "model": "llama-3.3-70b-versatile",
                "messages": [
                    {"role": "system", "content": _FORMAT_SYSTEM},
                    {"role": "user",   "content": user_msg},
                ],
                "temperature": 0.3,
                "max_tokens": 4096,
            },
            timeout=90,
        )
    else:
        # OpenRouter — Nemo (works well for PDF and XLSX)
        print(f"  [Format Agent] Generating {doc_type.upper()} formatting code via Nemo...")
        resp = requests.post(
            "https://openrouter.ai/api/v1/chat/completions",
            headers={
                "Authorization": f"Bearer {OPENROUTER_API_KEY}",
                "Content-Type": "application/json",
            },
            json={
                "model": "nvidia/nemotron-3-super-120b-a12b:free",
                "messages": [
                    {"role": "system", "content": _FORMAT_SYSTEM},
                    {"role": "user",   "content": user_msg},
                ],
            },
            timeout=90,
        )

    resp.raise_for_status()
    raw = resp.json()["choices"][0]["message"]["content"].strip()
    raw = re.sub(r"^```(?:python)?\n?", "", raw)
    raw = re.sub(r"\n?```$", "", raw)
    return raw.strip()


# ─────────────────────────────────────────────────────────────────────────────
#  CODE EXECUTOR — runs Claude's generated render_document()
# ─────────────────────────────────────────────────────────────────────────────
def run_format_code(code: str, data: dict) -> str:
    from openpyxl.styles import PatternFill, Font, Alignment, Border, Side
    from openpyxl.utils import get_column_letter
    from openpyxl import Workbook
    from openpyxl.chart import BarChart, LineChart, PieChart, Reference, Series
    from openpyxl.chart.series import DataPoint
    from pptx import Presentation
    from pptx.util import Inches, Pt, Emu
    from pptx.dml.color import RGBColor
    from pptx.enum.text import PP_ALIGN
    from reportlab.platypus import (
        SimpleDocTemplate, Paragraph, Spacer, Image as RLImage,
        Table, TableStyle, HRFlowable, KeepTogether,
    )
    from reportlab.lib.styles import getSampleStyleSheet, ParagraphStyle
    from reportlab.lib import colors
    from reportlab.lib.pagesizes import A4, LETTER
    from reportlab.lib.units import cm, inch
    from reportlab.lib.enums import TA_CENTER, TA_JUSTIFY, TA_LEFT, TA_RIGHT

    namespace = {
        "io": io, "json": json, "os": os,
        "Presentation": Presentation, "Inches": Inches, "Pt": Pt,
        "Emu": Emu, "RGBColor": RGBColor, "PP_ALIGN": PP_ALIGN,
        "Workbook": Workbook, "PatternFill": PatternFill, "Font": Font,
        "Alignment": Alignment, "Border": Border, "Side": Side,
        "get_column_letter": get_column_letter,
        "BarChart": BarChart, "LineChart": LineChart, "PieChart": PieChart,
        "Reference": Reference, "Series": Series, "DataPoint": DataPoint,
        "SimpleDocTemplate": SimpleDocTemplate, "Paragraph": Paragraph,
        "Spacer": Spacer, "RLImage": RLImage, "Table": Table,
        "TableStyle": TableStyle, "HRFlowable": HRFlowable,
        "KeepTogether": KeepTogether, "ParagraphStyle": ParagraphStyle,
        "getSampleStyleSheet": getSampleStyleSheet,
        "colors": colors, "A4": A4, "LETTER": LETTER,
        "cm": cm, "inch": inch,
        "TA_CENTER": TA_CENTER, "TA_JUSTIFY": TA_JUSTIFY,
        "TA_LEFT": TA_LEFT, "TA_RIGHT": TA_RIGHT,
    }

    try:
        exec(code, namespace)
        result = namespace["render_document"](data, fetch_pexels_image)
        return result
    except Exception as e:
        return f"Error executing format code: {e}\n\nCode was:\n{code[:500]}..."


# ─────────────────────────────────────────────────────────────────────────────
#  CONTEXT BUILDER
# ─────────────────────────────────────────────────────────────────────────────
def _build_context(doc_type: str, data: dict) -> str:
    if doc_type == "pptx":
        titles = [s.get("title", "") for s in data.get("slides", [])]
        return (
            f"Topic: {data.get('title')} — {data.get('subtitle')}\n"
            f"Slides ({len(titles)}): {', '.join(titles)}"
        )
    elif doc_type == "pdf":
        headings = [s.get("heading", "") for s in data.get("sections", [])]
        return (
            f"Topic: {data.get('title')}\n"
            f"Sections ({len(headings)}): {', '.join(headings)}"
        )
    elif doc_type == "xlsx":
        return (
            f"Sheet: {data.get('sheet_name')}\n"
            f"Columns: {', '.join(data.get('columns', []))}\n"
            f"Rows: {len(data.get('rows', []))}"
        )
    return str(data)


# ─────────────────────────────────────────────────────────────────────────────
#  WORKER 1 — PPTX
# ─────────────────────────────────────────────────────────────────────────────
def create_presentation(title: str, subtitle: str, slides_json: str) -> str:
    """
    Creates a context-aware styled PowerPoint presentation.

    slides_json: JSON list. Each slide object supports:
      - "title"         : Slide heading (string)
      - "content"       : Bullet points (list of strings)
      - "image_keyword" : 2-4 word Pexels search phrase (string)
      - "accent_color"  : Hex color hint, e.g. "#1E90FF" (string)
      - "icon_emoji"    : Single emoji prefix for the title (string)
      - "callout_stat"  : One bold stat shown in a highlight box (string)
    """
    try:
        slides = json.loads(slides_json)
    except json.JSONDecodeError as e:
        return f"Error: Invalid slides_json — {e}"

    data = {"title": title, "subtitle": subtitle, "slides": slides}

    format_code = call_format_agent("pptx", _build_context("pptx", data))

    last_generated["tool"]        = "presentation"
    last_generated["params"]      = data
    last_generated["format_code"] = format_code

    return run_format_code(format_code, data)


# ─────────────────────────────────────────────────────────────────────────────
#  WORKER 2 — XLSX
# ─────────────────────────────────────────────────────────────────────────────
def create_spreadsheet(
    sheet_name: str,
    columns_json: str,
    rows_json: str,
    highlight_top_n: int = 3,
    number_format_cols_json: str = "[]",
    freeze_header: bool = True,
) -> str:
    """
    Creates a context-aware styled Excel spreadsheet.

    Args:
        sheet_name              : Name of the worksheet tab.
        columns_json            : JSON list of column header strings.
        rows_json               : JSON list of row arrays.
        highlight_top_n         : How many top rows to highlight (default 3).
        number_format_cols_json : JSON list of numeric column names.
        freeze_header           : Whether to freeze the top row (default True).
    """
    try:
        columns  = json.loads(columns_json)
        rows     = json.loads(rows_json)
        num_cols = json.loads(number_format_cols_json)
    except json.JSONDecodeError as e:
        return f"Error: Invalid JSON — {e}"

    data = {
        "sheet_name": sheet_name, "columns": columns, "rows": rows,
        "highlight_top_n": highlight_top_n, "number_format_cols": num_cols,
        "freeze_header": freeze_header,
    }

    format_code = call_format_agent("xlsx", _build_context("xlsx", data))

    last_generated["tool"]        = "spreadsheet"
    last_generated["params"]      = data
    last_generated["format_code"] = format_code

    return run_format_code(format_code, data)


# ─────────────────────────────────────────────────────────────────────────────
#  WORKER 3 — PDF
# ─────────────────────────────────────────────────────────────────────────────
def create_report(title: str, sections_json: str) -> str:
    """
    Creates a context-aware styled PDF report.

    sections_json: JSON list. Each section object supports:
      - "heading"       : Section title (string)
      - "content"       : Body paragraph text (string)
      - "image_keyword" : 2-4 word Pexels search phrase (string)
      - "callout"       : Key stat or highlight (string)
      - "section_type"  : "normal" | "highlight" | "warning" | "tip" (string)
      - "table_data"    : 2D list — first row = headers (list of lists)
    """
    try:
        sections = json.loads(sections_json)
    except json.JSONDecodeError as e:
        return f"Error: Invalid sections_json — {e}"

    data = {"title": title, "sections": sections}

    format_code = call_format_agent("pdf", _build_context("pdf", data))

    last_generated["tool"]        = "report"
    last_generated["params"]      = data
    last_generated["format_code"] = format_code

    return run_format_code(format_code, data)


# ─────────────────────────────────────────────────────────────────────────────
#  REVISION TOOL
# ─────────────────────────────────────────────────────────────────────────────
def revise_document(
    feedback: str,
    revised_params_json: str,
    format_feedback: str = "",
) -> str:
    """
    Re-generates the last document with updated content and/or formatting.

    Args:
        feedback            : Plain-English description of content changes (for logging).
        revised_params_json : COMPLETE updated document parameters as JSON.
                              Schema matches the original tool:
                                Presentation : {"title","subtitle","slides":[...]}
                                Report       : {"title","sections":[...]}
                                Spreadsheet  : {"sheet_name","columns","rows",...}
        format_feedback     : Optional. Plain-English description of FORMATTING changes
                              e.g. "use a dark background", "switch to a minimal monochrome palette",
                              "make headings green", "use a warmer colour scheme".
                              Leave empty string if only content is changing.
    """
    if not last_generated["tool"]:
        return "Error: No document has been generated yet. Please generate one first."

    try:
        revised = json.loads(revised_params_json)
    except json.JSONDecodeError as e:
        return f"Error: Invalid revised_params_json — {e}"

    tool = last_generated["tool"]
    print(f"\n  [Revision] Content: {feedback}")

    doc_type_map = {"presentation": "pptx", "report": "pdf", "spreadsheet": "xlsx"}
    doc_type     = doc_type_map[tool]
    existing_code = last_generated.get("format_code")

    if format_feedback:
        print(f"  [Revision] Format : {format_feedback}")
        context     = _build_context(doc_type, revised)
        format_code = call_format_agent(doc_type, context, existing_code, format_feedback)
    else:
        print(f"  [Revision] Reusing existing format code (content-only change).")
        format_code = existing_code

    last_generated["params"]      = revised
    last_generated["format_code"] = format_code

    return run_format_code(format_code, revised)


